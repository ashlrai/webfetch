5c:T27f6,{"@context":"https://schema.org","@type":"CollectionPage","name":"Real images, real licenses — webfetch gallery","description":"A live gallery of public-domain and Creative Commons images fetched through webfetch. Every entry is license-stamped with full attribution and a link back to the origin.","url":"https://getwebfetch.com/#gallery","hasPart":[{"@type":"ImageObject","name":"Girl with a Pearl Earring (c. 1665)","contentUrl":"https://getwebfetch.com/gallery/vermeer-girl-pearl-earring.jpg","thumbnailUrl":"https://getwebfetch.com/gallery/vermeer-girl-pearl-earring-600.webp","creator":{"@type":"Person","name":"Johannes Vermeer"},"creditText":"Johannes Vermeer · Public Domain · via Wikimedia Commons","copyrightNotice":"Johannes Vermeer · Public Domain · via Wikimedia Commons","license":"https://en.wikipedia.org/wiki/Public_domain","acquireLicensePage":"https://commons.wikimedia.org/wiki/File:1665_Girl_with_a_Pearl_Earring.jpg","isAccessibleForFree":true,"provider":{"@type":"Organization","name":"wikimedia"}},{"@type":"ImageObject","name":"The Blue Marble (Apollo 17, 1972)","contentUrl":"https://getwebfetch.com/gallery/earth-apollo-17-blue-marble.jpg","thumbnailUrl":"https://getwebfetch.com/gallery/earth-apollo-17-blue-marble-600.webp","creator":{"@type":"Person","name":"NASA / Apollo 17 crew"},"creditText":"NASA · Public Domain · via Wikimedia Commons","copyrightNotice":"NASA · Public Domain · via Wikimedia Commons","license":"https://en.wikipedia.org/wiki/Public_domain","acquireLicensePage":"https://commons.wikimedia.org/wiki/File:The_Earth_seen_from_Apollo_17.jpg","isAccessibleForFree":true,"provider":{"@type":"Organization","name":"wikimedia"}},{"@type":"ImageObject","name":"Aurora Borealis over Bear Lake, Alaska","contentUrl":"https://getwebfetch.com/gallery/aurora-borealis.jpg","thumbnailUrl":"https://getwebfetch.com/gallery/aurora-borealis-600.webp","creator":{"@type":"Person","name":"United States Air Force (Senior Airman Joshua Strang)"},"creditText":"USAF / Joshua Strang · Public Domain · via Wikimedia Commons","copyrightNotice":"USAF / Joshua Strang · Public Domain · via Wikimedia Commons","license":"https://en.wikipedia.org/wiki/Public_domain","acquireLicensePage":"https://commons.wikimedia.org/wiki/File:Polarlicht_2.jpg","isAccessibleForFree":true,"provider":{"@type":"Organization","name":"wikimedia"}},{"@type":"ImageObject","name":"The Starry Night (1889)","contentUrl":"https://getwebfetch.com/gallery/starry-night-van-gogh.jpg","thumbnailUrl":"https://getwebfetch.com/gallery/starry-night-van-gogh-600.webp","creator":{"@type":"Person","name":"Vincent van Gogh"},"creditText":"Vincent van Gogh · Public Domain · via Wikimedia Commons","copyrightNotice":"Vincent van Gogh · Public Domain · via Wikimedia Commons","license":"https://en.wikipedia.org/wiki/Public_domain","acquireLicensePage":"https://commons.wikimedia.org/wiki/File:Van_Gogh_-_Starry_Night_-_Google_Art_Project.jpg","isAccessibleForFree":true,"provider":{"@type":"Organization","name":"wikimedia"}},{"@type":"ImageObject","name":"The Great Wave off Kanagawa (c. 1831)","contentUrl":"https://getwebfetch.com/gallery/great-wave-hokusai.jpg","thumbnailUrl":"https://getwebfetch.com/gallery/great-wave-hokusai-600.webp","creator":{"@type":"Person","name":"Katsushika Hokusai"},"creditText":"Katsushika Hokusai · Public Domain · via Wikimedia Commons","copyrightNotice":"Katsushika Hokusai · Public Domain · via Wikimedia Commons","license":"https://en.wikipedia.org/wiki/Public_domain","acquireLicensePage":"https://commons.wikimedia.org/wiki/File:Tsunami_by_hokusai_19th_century.jpg","isAccessibleForFree":true,"provider":{"@type":"Organization","name":"wikimedia"}},{"@type":"ImageObject","name":"Redwood National Park, fog in the forest","contentUrl":"https://getwebfetch.com/gallery/redwood-fog.jpg","thumbnailUrl":"https://getwebfetch.com/gallery/redwood-fog-600.webp","creator":{"@type":"Person","name":"National Park Service"},"creditText":"NPS · Public Domain · via W