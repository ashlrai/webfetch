14:["$","section",null,{"className":"max-w-3xl mx-auto px-6 py-20","children":[["$","h2",null,{"className":"text-3xl font-semibold tracking-tight mb-8","children":"FAQ"}],["$","div",null,{"className":"divide-y divide-[var(--border)]","children":[["$","details","What counts as a fetch?",{"className":"group py-5","children":[["$","summary",null,{"className":"cursor-pointer font-medium flex items-center justify-between list-none","children":[["$","span",null,{"children":"What counts as a fetch?"}],["$","span",null,{"className":"text-[var(--fg-dim)] group-open:text-[var(--accent)] transition-colors","children":"+"}]]}],["$","p",null,{"className":"mt-3 text-[var(--fg-dim)] leading-relaxed","children":"A fetch is one successful /search, /download, or /probe call on the cloud API. Local usage against self-hosted CLI/MCP is unlimited and never counted. Cached hits (SHA-256 cache) are free."}]]}],["$","details","Is this commercial safe?",{"className":"group py-5","children":[["$","summary",null,{"className":"cursor-pointer font-medium flex items-center justify-between list-none","children":[["$","span",null,{"children":"Is this commercial safe?"}],["$","span",null,{"className":"text-[var(--fg-dim)] group-open:text-[var(--accent)] transition-colors","children":"+"}]]}],["$","p",null,{"className":"mt-3 text-[var(--fg-dim)] leading-relaxed","children":"Yes, when you stay on the default license policy (safe-only). Results are ranked CC0 > PUBLIC_DOMAIN > CC_BY > CC_BY_SA > EDITORIAL_LICENSED, and UNKNOWN is rejected. Attribution strings are pre-built so you can ship directly. Browser-sourced images always get a sidecar and require opt-in."}]]}],["$","details","Can I self-host?",{"className":"group py-5","children":[["$","summary",null,{"className":"cursor-pointer font-medium flex items-center justify-between list-none","children":[["$","span",null,{"children":"Can I self-host?"}],["$","span",null,{"className":"text-[var(--fg-dim)] group-open:text-[var(--accent)] transition-colors","children":"+"}]]}],["$","p",null,{"className":"mt-3 text-[var(--fg-dim)] leading-relaxed","children":"Yes. The CLI, MCP server, HTTP server, and core library are MIT-licensed. The cloud (metering, dashboard, managed browser) is the paid layer. Enterprise can run a dedicated tenant or on-prem Node + SQLite build."}]]}],["$","details","What if I need a custom provider?",{"className":"group py-5","children":[["$","summary",null,{"className":"cursor-pointer font-medium flex items-center justify-between list-none","children":[["$","span",null,{"children":"What if I need a custom provider?"}],["$","span",null,{"className":"text-[var(--fg-dim)] group-open:text-[var(--accent)] transition-colors","children":"+"}]]}],["$","p",null,{"className":"mt-3 text-[var(--fg-dim)] leading-relaxed","children":"Pro+ ships a provider plugin surface. Enterprise gets custom provider adapters built for you. The adapter interface is ~50 lines of TypeScript — fetch + map to the canonical candidate shape."}]]}],["$","details","How is this different from Unsplash or Google Images?",{"className":"group py-5","children":[["$","summary",null,{"className":"cursor-pointer font-medium flex items-center justify-between list-none","children":[["$","span",null,{"children":"How is this different from Unsplash or Google Images?"}],["$","span",null,{"className":"text-[var(--fg-dim)] group-open:text-[var(--accent)] transition-colors","children":"+"}]]}],["$","p",null,{"className":"mt-3 text-[var(--fg-dim)] leading-relaxed","children":"Unsplash is one source under one license. Google Images has no usable API and zero license metadata. webfetch federates 19+ licensed sources, ranks them license-first, and falls through to a human-like browser only when you opt in — with attribution sidecars on everything it returns."}]]}],"$L1b"]}]]}]
