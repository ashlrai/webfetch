1b:["$","details","What about copyright on browser-sourced images?",{"className":"group py-5","children":[["$","summary",null,{"className":"cursor-pointer font-medium flex items-center justify-between list-none","children":[["$","span",null,{"children":"What about copyright on browser-sourced images?"}],["$","span",null,{"className":"text-[var(--fg-dim)] group-open:text-[var(--accent)] transition-colors","children":"+"}]]}],["$","p",null,{"className":"mt-3 text-[var(--fg-dim)] leading-relaxed","children":"Browser-sourced images come back with license: UNKNOWN by default and require an explicit opt-in per call. Every one ships with a sidecar JSON containing source URL, screenshot thumbnail, and extracted metadata. You own the compliance decision; we make it easy to record and audit."}]]}]
