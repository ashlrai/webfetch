12:["$","tr","Serper / SerpAPI",{"className":"border-t border-[var(--border)] ","children":[["$","td",null,{"className":"px-4 py-3 font-mono","children":["$","span",null,{"className":"text-[var(--fg)]","children":"Serper / SerpAPI"}]}],[["$","td","0",{"className":"px-4 py-3","children":["$","span",null,{"className":"text-[var(--fg-dim)]","children":"no"}]}],["$","td","1",{"className":"px-4 py-3","children":["$","span",null,{"className":"text-[var(--fg-dim)]","children":"partial"}]}],["$","td","2",{"className":"px-4 py-3","children":["$","span",null,{"className":"text-[var(--fg-dim)]","children":"no"}]}],["$","td","3",{"className":"px-4 py-3","children":["$","span",null,{"className":"text-[var(--fg-dim)]","children":"no"}]}],["$","td","4",{"className":"px-4 py-3","children":["$","span",null,{"className":"text-[var(--fg-dim)]","children":"no"}]}],["$","td","5",{"className":"px-4 py-3","children":["$","span",null,{"className":"text-[var(--accent)] font-medium","children":"yes"}]}],["$","td","6",{"className":"px-4 py-3","children":["$","span",null,{"className":"text-[var(--accent)] font-medium","children":"yes"}]}]]]}]
13:["$","div",null,{"className":"mt-16 space-y-10 prose-wf","children":[["$","div",null,{"children":[["$","h2",null,{"children":"vs Google Images"}],["$","p",null,{"children":"Google's Image Search API was retired in 2011. The only way to script Google Images is through third-party scraping (SerpAPI, Serper) or the SERP-less workaround of a browser fetcher. None of these return license metadata. webfetch uses Google as a last resort (browser fallback, opt-in), and only after trying 19 licensed sources that Google doesn't surface."}]]}],["$","div",null,{"children":[["$","h2",null,{"children":"vs Unsplash API"}],["$","p",null,{"children":"Unsplash is excellent — it's one of our 19 providers. But Unsplash alone can't cover editorial music art, public-domain museum scans, CC-licensed Flickr, government archives, or the long tail. One source is one bet."}]]}],["$","div",null,{"children":[["$","h2",null,{"children":"vs Bing Image Search"}],["$","p",null,{"children":"Bing returns URLs without license. You have to interpret the \"license\" filter parameters yourself, and the filter is opaque. webfetch lets you use Bing as a provider (opt-in), and coerces host-based license heuristics, but never pretends it knows what it doesn't."}]]}],["$","div",null,{"children":[["$","h2",null,{"children":"vs Serper / SerpAPI"}],["$","p",null,{"children":"Serper and SerpAPI are excellent SERP scrapers. They surface Google Images results with no license data. webfetch uses them (opt-in) as one of 19 providers and attaches a host-based heuristic + UNKNOWN tag so you know what you're shipping."}]]}]]}]
