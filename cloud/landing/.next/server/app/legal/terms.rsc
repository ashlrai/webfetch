9:["$","$1","c",{"children":[["$","article",null,{"className":"max-w-3xl mx-auto px-6 py-20 prose-wf","children":[["$","h1",null,{"children":"Terms of Service"}],["$","p",null,{"children":["$","em",null,{"children":"Last updated: April 13, 2026."}]}],["$","h2",null,{"children":"1. Agreement"}],["$","p",null,{"children":"By using webfetch.dev, api.webfetch.dev, or any @webfetch/* package, you agree to these terms. If you disagree, do not use the service."}],["$","h2",null,{"children":"2. The service"}],["$","p",null,{"children":"webfetch is a federated image search and fetching layer. The open-source packages are licensed under MIT (see the LICENSE file in each package). The hosted cloud service at api.webfetch.dev is a paid-usage managed offering with metered fetches."}],["$","h2",null,{"children":"3. Your content and compliance"}],["$","p",null,{"children":"webfetch surfaces images from third-party sources. You are responsible for complying with each source's license and terms. webfetch provides license-first ranking, attribution strings, and sidecar metadata as compliance tools — not as legal advice."}],["$","h2",null,{"children":"4. Browser-sourced images"}],["$","p",null,{"children":["Images retrieved via the opt-in browser fallback come with ",["$","code",null,{"children":"license: UNKNOWN"}]," ","and a sidecar containing the source URL. You are solely responsible for determining whether your use is lawful. Ashlar AI provides no warranty on copyright clearance for browser-sourced images. Enterprise customers may purchase legal indemnification as a separate rider."]}],["$","h2",null,{"children":"5. Billing and refunds"}],["$","p",null,{"children":"Paid tiers are billed monthly or annually via Stripe. Overage fees are metered per fetch and invoiced at the end of each cycle. Refunds are prorated at our discretion."}],["$","h2",null,{"children":"6. Acceptable use"}],["$","p",null,{"children":"You may not use webfetch to violate applicable law, circumvent access controls, or mass scrape sites in violation of their terms of service. Abuse results in account termination without refund."}],["$","h2",null,{"children":"7. Disclaimers"}],["$","p",null,{"children":"The service is provided \"as is\" without warranty of any kind. Ashlar AI is not liable for indirect or consequential damages."}],["$","h2",null,{"children":"8. Changes"}],["$","p",null,{"children":"We may update these terms with at least 30 days' notice to active customers."}],["$","h2",null,{"children":"Contact"}],["$","p",null,{"children":"legal@webfetch.dev"}]]}],null,["$","$Lc",null,{"children":["$Ld",["$","$Le",null,{"promise":"$@f"}]]}]]}]
